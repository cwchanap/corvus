# Development environment variables for Cloudflare Workers (API)
# Copy this file to .dev.vars and fill in real values before running `wrangler dev`

# Google OAuth credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google OAuth redirect URI for local development
# Use the web dev server origin (port 5000) so the callback and final
# /dashboard redirect stay on the running web app, not the API Worker.
# Overrides the production value from wrangler.jsonc during wrangler dev.
GOOGLE_REDIRECT_URI="http://localhost:5000/auth/google/callback"

# Comma-separated list of extension origins allowed to make credentialed
# cross-site requests.  In development (DEV=1) all extension origins are
# allowed, so this is only needed in production.
# ALLOWED_EXTENSION_ORIGINS="chrome-extension://your-extension-id"
